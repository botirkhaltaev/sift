def bench_linux_literal_default(suite_dir):
    '''
    Benchmark the speed of a literal using *default* settings.
    Sift uses default settings (includes hidden files unlike rg default).
    '''
    require(suite_dir, 'linux')
    cwd = path.join(suite_dir, LINUX_DIR)
    pat = 'PM_RESUME'

    def mkcmd(*args, **kwargs):
        kwargs['cwd'] = cwd
        return Command(*args, **kwargs)

    sift_dir = ensure_sift_index(cwd)
    return Benchmark(
        pattern=pat, corpus_dir=cwd, category='literal',
        commands=[
            mkcmd('rg', ['rg', pat]),
            mkcmd('sift', sift_cmd(sift_dir, pat, flags=[])),
        ])


